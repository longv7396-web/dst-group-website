{
  "name": "dst-group-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "build:hosting": "tsc --noEmit && vite build --base=/dst-group/",
    "lint": "tsc --noEmit",
    "preview": "vite preview --host 127.0.0.1",
    "extract:pdf": "node scripts/extract-pdf-content.mjs",
    "extract:showcase": "node scripts/extract-high-quality-assets.js",
    "images:audit": "node scripts/check-travel-images.mjs",
    "travel:import": "node scripts/convert-travel-csv.mjs",
    "prebuild": "node scripts/convert-travel-csv.mjs && node scripts/check-travel-images.mjs"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.19.7",
    "@vitejs/plugin-react": "^5.0.0",
    "framer-motion": "^12.23.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "pdfjs-dist": "^4.10.38",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
